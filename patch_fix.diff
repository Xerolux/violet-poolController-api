        return {
            "base_module": not self.dosing_standalone,
            "dosing_module": self.dosing_standalone or is_present("SYSTEM_dosagemodule_cpu_temperature"),
            "extension_module_1": is_present("EXT1_1"),
            "extension_module_2": is_present("EXT2_1"),
